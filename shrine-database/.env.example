# ══════════════════════════════════════════════════════════════
#  Shrine Database API — Environment Configuration
#  Copy this file to .env and fill in every value before starting.
#  Never commit .env to git — it is listed in .gitignore.
# ══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
# The port the API listens on. Render sets this automatically.
PORT=3000

# Set to "production" on Render. Controls error verbosity and startup validation.
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# MongoDB connection string.
# Local dev:  mongodb://localhost/shrines
# Production: get this from MongoDB Atlas → Connect → Drivers
#   Format:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/shrines
MONGODB_URI=mongodb://localhost/shrines

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API.
# Set to your shrine-finder Render URL in production.
# Example: https://shrine-finder.onrender.com,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Stripe Payments ───────────────────────────────────────────
# Get these from https://dashboard.stripe.com
#
# Secret key — use sk_test_... for dev, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Webhook secret — from Stripe Dashboard → Webhooks → your endpoint → Signing secret.
# For local testing use the Stripe CLI: stripe listen --forward-to localhost:3000/api/payment/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs — create Products in Stripe Dashboard, then copy the Price ID (starts with price_).
# Developer plan: $9/month recurring
STRIPE_DEVELOPER_PRICE_ID=price_your_developer_plan_id_here

# Pro plan: $29/month recurring
STRIPE_PRO_PRICE_ID=price_your_pro_plan_id_here
