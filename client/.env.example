# ══════════════════════════════════════════════════════════════
#  Shrine Finder (Frontend) — Environment Configuration
#  Copy this file to .env and fill in every value before building.
#  Never commit .env to git — it is listed in .gitignore.
#  All variables MUST start with VITE_ to be available in the browser.
# ══════════════════════════════════════════════════════════════

# ── API ───────────────────────────────────────────────────────
# The base URL of the server backend.
# Local dev:  http://localhost:3000
# Production: your shrine-api Render service URL (no trailing slash)
VITE_API_BASE=http://localhost:3000

# ── GitHub Repository ─────────────────────────────────────────
# Full URL to the public GitHub repo. Used in header, footer, and pricing page.
VITE_GITHUB_URL=https://github.com/webDeveloper42/shrines-api

# ── App Name ──────────────────────────────────────────────────
# Displayed in the footer logo. Change this if you fork the project.
VITE_APP_NAME=Shrine Database
