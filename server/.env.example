# ══════════════════════════════════════════════════════════════
#  Shrine Database API — Environment Configuration
#  Copy this file to .env and fill in every value before starting.
#  Never commit .env to git — it is listed in .gitignore.
# ══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Local:      mongodb://localhost/shrines
# Production: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/shrines
MONGODB_URI=mongodb://localhost/shrines

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production: set to your client Render URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ══════════════════════════════════════════════════════════════
#  Stripe — OPTIONAL for local development
#
#  The API runs fully without these. Registration, browsing, and
#  authentication all work without Stripe. Payment routes return
#  a clear "not configured" message instead of crashing.
#
#  Only fill these in if you want to test the upgrade flow locally.
# ══════════════════════════════════════════════════════════════

# Step 1 — Create a free Stripe account at https://stripe.com
#           and get your test keys from https://dashboard.stripe.com/test/apikeys

# Step 2 — Paste your test secret key here (starts with sk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Step 3 — Install the Stripe CLI: https://stripe.com/docs/stripe-cli
#           Run in a separate terminal: npm run stripe:listen
#           Copy the webhook signing secret it prints and paste it below.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Step 4 — Create two Products in the Stripe Dashboard (test mode):
#           - "Shrine Database Developer" — $9/month recurring
#           - "Shrine Database Pro"       — $29/month recurring
#           Copy each Price ID (starts with price_) and paste below.
STRIPE_DEVELOPER_PRICE_ID=price_your_developer_plan_id_here
STRIPE_PRO_PRICE_ID=price_your_pro_plan_id_here

# ── Local Stripe test flow ────────────────────────────────────
# 1. npm start                (terminal 1 — API)
# 2. npm run stripe:listen    (terminal 2 — forwards Stripe events to :3000)
# 3. POST /api/payment/upgrade with your API key and tier
# 4. Complete checkout with Stripe test card: 4242 4242 4242 4242
# 5. The webhook fires → your key tier updates automatically
